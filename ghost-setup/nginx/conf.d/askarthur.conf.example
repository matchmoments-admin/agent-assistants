server {
    listen 80;
    server_name blog.askarthur.au;
    return 301 https://$server_name$request_uri;
}

server {
    listen 443 ssl http2;
    server_name blog.askarthur.au;

    ssl_certificate /etc/letsencrypt/live/askarthur.au/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/askarthur.au/privkey.pem;

    add_header X-Frame-Options "SAMEORIGIN";
    add_header X-Content-Type-Options "nosniff";

    # Keep Ghost admin, members, feeds, and static assets on this subdomain
    location ~ ^/(ghost|members|content|assets|public|p|rss|sitemap.*\.xml|robots\.txt|favicon\.ico) {
        proxy_pass http://ghost-askarthur:2368;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_buffering off;
    }

    # 301 post slugs to the canonical URL on the main site so SEO consolidates there
    location / {
        return 301 https://askarthur.au/blog$request_uri;
    }
}
